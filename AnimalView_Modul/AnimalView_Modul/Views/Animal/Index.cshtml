@inherits DotNetNuke.Web.Mvc.Framework.DnnWebViewPage<List<AnimalView.Dnn.AnimalView_Modul.Models.Animal>>

@*@{
        Layout = null;
    }*@
<h1>Szakállas agámák</h1>
@if (Model.Count == 0)
{
    <p>Nincsenek állatok</p>
}
@foreach (var animal in Model)
{
    <div>@animal.Name;</div>
    <div>@animal.Gender;</div>
    <div>@animal.BirthDate;</div>
    <div>@animal.Genetics;</div>
    <div>@animal.Personality;</div>
    <div>@animal.Price</div>
}
<script>
    var a = @Model.Count
    console.log(a)
</script>